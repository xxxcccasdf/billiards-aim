<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_container"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <!-- 主内容区域 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/floating_bg">

        <!-- 拖动条/标题栏 -->
        <LinearLayout
            android:id="@+id/control_bar"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp"
            android:background="@drawable/control_bar_bg">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="台球瞄准"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:alpha="0.9" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="设置"
                android:scaleType="centerInside"
                android:padding="6dp" />

            <ImageButton
                android:id="@+id/btn_minimize"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="最小化"
                android:scaleType="centerInside"
                android:padding="6dp" />

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:contentDescription="关闭"
                android:scaleType="centerInside"
                android:padding="6dp" />
        </LinearLayout>

        <!-- WebView -->
        <WebView
            android:id="@+id/web_view"
            android:layout_width="320dp"
            android:layout_height="420dp"
            android:background="@android:color/transparent" />

        <!-- 控制面板 -->
        <LinearLayout
            android:id="@+id/control_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#CC1a1a2e"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="透明度"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:alpha="0.7" />

            <SeekBar
                android:id="@+id/opacity_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="50"
                android:progressTint="#f0c040"
                android:thumbTint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <!-- 调整大小手柄 -->
    <View
        android:id="@+id/resize_handle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/resize_icon" />

</FrameLayout>
