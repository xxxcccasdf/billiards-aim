<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/main_bg">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎱 台球瞄准辅助"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#f0c040"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="悬浮窗辅助瞄准工具"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1a1a2e"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#333344"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检查权限中..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="正在检查必要权限..."
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_gravity="center_horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_float"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="启动悬浮窗"
                android:textSize="16sp"
                android:textColor="#111111"
                app:backgroundTint="#f0c040"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_stop_float"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="关闭悬浮窗"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#333344"
                app:cornerRadius="12dp"
                android:enabled="false" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="使用说明：
1. 开启悬浮窗权限
2. 点击启动悬浮窗
3. 切换到台球游戏
4. 拖动球调整位置"
        android:textSize="12sp"
        android:textColor="#666666"
        android:lineSpacingMultiplier="1.4"
        android:gravity="center" />

</LinearLayout>
